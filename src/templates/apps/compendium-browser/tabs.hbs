<nav class="tabs" data-group="tabs" role="tablist" aria-label="Compendium Browser Tabs">
    {{#each tabs as |tab|}}
    <a class="{{#if tab.active}}active{{/if}}" data-group="tabs" data-tab="{{tab.id}}" data-action="tab" role="tab" aria-selected="{{#if tab.active}}true{{else}}false{{/if}}" tabindex="{{#if tab.active}}0{{else}}-1{{/if}}">
        <i class="{{ tab.icon }}"></i> {{ localize (concatStrings "SR5.CompendiumBrowser.Tabs." tab.label) }}
    </a>
    {{/each}}
</nav>
