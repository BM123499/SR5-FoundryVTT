<div class="compendium-filters">
    <div class="search-bar">
        <label class="sr-only" for="compendium-browser-search">{{localize "SR5.CompendiumBrowser.Filters.SearchPlaceholder"}}</label>
        <i class="search-icon fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        <input 
            type="text" 
            name="search" 
            id="compendium-browser-search"
            value="{{searchQuery}}" 
            placeholder="{{localize "SR5.CompendiumBrowser.Filters.SearchPlaceholder"}}"
            aria-label="{{localize "SR5.CompendiumBrowser.Filters.SearchPlaceholder"}}">
        <button type="button" class="clear-filter" data-action="clearSearch" title="{{localize "SR5.CompendiumBrowser.Filters.ClearSearch"}}" aria-label="{{localize "SR5.CompendiumBrowser.Filters.ClearSearch"}}">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <div class="types">
        {{#each types as |type|}}
        <label class="type">
            <input 
                type="checkbox" 
                data-type="{{type.id}}" 
                {{#if type.selected}}checked{{/if}}>
            <span>{{type.value}}</span>
        </label>
        {{/each}}
    </div>
</div>
